// NEET/JEE Educational Portal — data model
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (Auth.js / NextAuth v5) + roles
// ---------------------------------------------------------------------------

enum Role {
  STUDENT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for pure-OAuth accounts
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  attempts        TestAttempt[]
  analyticsEvents AnalyticsEvent[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Question bank taxonomy: Exam -> Subject -> Topic -> Subtopic
// ---------------------------------------------------------------------------

model Exam {
  id          String  @id @default(cuid())
  name        String // e.g. "NEET UG"
  slug        String  @unique // e.g. "neet-ug"
  description String?

  subjects  Subject[]
  papers    Paper[]
  questions Question[]
  createdAt DateTime   @default(now())
}

model Subject {
  id     String @id @default(cuid())
  name   String // e.g. "Physics"
  slug   String
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  topics    Topic[]
  questions Question[]

  @@unique([examId, slug])
  @@index([examId])
}

model Topic {
  id        String  @id @default(cuid())
  name      String // e.g. "Kinematics"
  slug      String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  subtopics Subtopic[]
  questions Question[]

  @@unique([subjectId, slug])
  @@index([subjectId])
}

model Subtopic {
  id      String @id @default(cuid())
  name    String
  slug    String
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  questions Question[]

  @@unique([topicId, slug])
  @@index([topicId])
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  questions QuestionTag[]
}

model QuestionTag {
  questionId String
  tagId      String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@index([tagId])
}

// ---------------------------------------------------------------------------
// Questions
// ---------------------------------------------------------------------------

enum QuestionType {
  MCQ_SINGLE // one correct option
  MCQ_MULTI // multiple correct options
  NUMERICAL // numeric answer (integer/decimal)
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Question {
  id       String       @id @default(cuid())
  type     QuestionType @default(MCQ_SINGLE)
  stem     String       @db.Text // question text (supports markdown / LaTeX)
  // For MCQ: JSON array of { key: "A", text: "..." }.
  options  Json?
  // For MCQ: JSON array of correct keys e.g. ["A"] or ["A","C"].
  // For NUMERICAL: JSON with { value, tolerance }.
  answer   Json
  solution String?      @db.Text // optional author-provided solution

  marks         Float      @default(4)
  negativeMarks Float      @default(1) // magnitude subtracted for wrong answers
  difficulty    Difficulty @default(MEDIUM)

  // Previous-year metadata
  year  Int?
  shift String? // e.g. "Shift 1"

  examId     String
  subjectId  String
  topicId    String?
  subtopicId String?

  exam     Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject  Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic    Topic?    @relation(fields: [topicId], references: [id], onDelete: SetNull)
  subtopic Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)

  tags           QuestionTag[]
  paperQuestions PaperQuestion[]
  attemptAnswers AttemptAnswer[]
  aiExplanations AIExplanation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([examId])
  @@index([subjectId])
  @@index([topicId])
  @@index([year])
}

// ---------------------------------------------------------------------------
// Papers (previous-year papers & mock tests) + ordering
// ---------------------------------------------------------------------------

enum PaperType {
  PREVIOUS_YEAR
  MOCK
}

model Paper {
  id           String    @id @default(cuid())
  title        String
  description  String?
  type         PaperType @default(PREVIOUS_YEAR)
  examId       String
  exam         Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  durationMins Int       @default(180)
  year         Int?
  isPublished  Boolean   @default(true)

  questions PaperQuestion[]
  attempts  TestAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([examId])
}

model PaperQuestion {
  id         String  @id @default(cuid())
  paperId    String
  questionId String
  order      Int
  section    String? // e.g. "Physics", "Section A"

  paper    Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([paperId, questionId])
  @@index([paperId])
}

// ---------------------------------------------------------------------------
// Attempts & answers
// ---------------------------------------------------------------------------

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

model TestAttempt {
  id          String        @id @default(cuid())
  userId      String
  paperId     String
  status      AttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now())
  submittedAt DateTime?
  // Denormalized results (populated on submit)
  score       Float?
  maxScore    Float?
  correct     Int?
  incorrect   Int?
  unattempted Int?

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper   Paper           @relation(fields: [paperId], references: [id], onDelete: Cascade)
  answers AttemptAnswer[]

  @@index([userId])
  @@index([paperId])
  @@index([status])
}

model AttemptAnswer {
  id              String   @id @default(cuid())
  attemptId       String
  questionId      String
  // Student's selected option keys or numerical value, as JSON.
  response        Json?
  isCorrect       Boolean?
  marksAwarded    Float?
  timeSpentMs     Int      @default(0)
  markedForReview Boolean  @default(false)

  attempt  TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([questionId])
}

// ---------------------------------------------------------------------------
// AI explanations (cached)
// ---------------------------------------------------------------------------

model AIExplanation {
  id         String   @id @default(cuid())
  questionId String
  model      String // e.g. "gpt-4o-mini"
  content    String   @db.Text
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, model])
  @@index([questionId])
}

// ---------------------------------------------------------------------------
// Analytics: detailed user tracking (who, what, how long)
// ---------------------------------------------------------------------------

enum EventType {
  PAGE_VIEW
  QUESTION_VIEW
  EXAM_START
  EXAM_SUBMIT
  AI_EXPLAIN
  LOGIN
  SIGNUP
}

model AnalyticsEvent {
  id         String    @id @default(cuid())
  userId     String?
  sessionId  String? // client-generated session id (groups a browsing session)
  type       EventType
  path       String? // route path for PAGE_VIEW
  entityType String? // "question" | "paper" | "exam" ...
  entityId   String?
  durationMs Int       @default(0) // time-on-page / time-on-question
  metadata   Json?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
}
